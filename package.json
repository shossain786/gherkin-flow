{
  "name": "gherkin-flow",
  "displayName": "Gherkin Flow",
  "description": "AI-powered BDD toolkit for VS Code. Generate scenarios from plain English, run & debug Cucumber tests with one click, catch quality issues before they ship. Supports Java, TypeScript, JavaScript, and Python.",
  "version": "0.9.46",
  "publisher": "RazaTech",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/shossain786/gherkin-flow"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Testing"
  ],
  "keywords": [
    "cucumber",
    "cucumber runner",
    "gherkin",
    "bdd",
    "bdd testing",
    "testing",
    "test runner",
    "qa automation",
    "maven",
    "gradle",
    "feature",
    "scenario",
    "java",
    "cucumber jvm",
    "cucumber-js",
    "javascript",
    "typescript",
    "nodejs",
    "python",
    "behave",
    "pytest-bdd",
    "step definitions",
    "automation",
    "ai",
    "copilot",
    "code generation",
    "natural language",
    "debug"
  ],
  "activationEvents": [
    "workspaceContains:**/*.feature"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "test": [
        {
          "id": "gherkinFlow.tagsView",
          "name": "Gherkin Tags",
          "when": "workspaceContainsFeatureFiles"
        }
      ]
    },
    "languages": [
      {
        "id": "gherkin",
        "aliases": ["Gherkin", "Cucumber"],
        "extensions": [".feature"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/icon.png",
          "dark": "./images/icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "gherkin",
        "scopeName": "text.gherkin.feature",
        "path": "./syntaxes/gherkin.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "gherkinFlow.runScenario",
        "title": "Run Scenario (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.runFeature",
        "title": "Run Feature File (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.generateSteps",
        "title": "Generate Missing Step Definitions (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.rerunFailed",
        "title": "Re-run Failed Scenarios (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.stopRun",
        "title": "Stop Running Test (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.dryRun",
        "title": "Dry Run Feature (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.openStepDef",
        "title": "Open Step Definition (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.watchScenario",
        "title": "Toggle Watch Scenario (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.showHistory",
        "title": "Show Scenario Run History (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.debugScenarioByName",
        "title": "Debug Scenario (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.openReport",
        "title": "Open HTML Report (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.generateFromNL",
        "title": "Generate Scenarios from Description (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.generateCIWorkflow",
        "title": "Generate CI Workflow (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.extractToBackground",
        "title": "Extract Steps to Background",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.renameStep",
        "title": "Rename Step Definition",
        "category": "GherkinFlow"
      }
    ],
    "configuration": {
      "title": "GherkinFlow",
      "properties": {
        "gherkinflow.lint.disable": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["GF001","GF002","GF003","GF004","GF005","GF006","GF007","GF008","GF009","GF010","GF011"]
          },
          "default": [],
          "markdownDescription": "Suppress specific GherkinFlow linter rules by code. Example: `[\"GF006\", \"GF007\"]` disables the UI-detail and jargon hints.\n\n| Code | Rule |\n|------|------|\n| GF001 | Duplicate scenario name |\n| GF002 | Scenario Outline with one example row |\n| GF003 | Scenario with no Then step |\n| GF004 | Scenario with no When step |\n| GF005 | Scenario with more than 8 steps |\n| GF006 | UI implementation detail in step text |\n| GF007 | Developer jargon in step text |\n| GF008 | Feature with no scenarios |\n| GF009 | Background with more than 4 steps |\n| GF010 | Hardcoded value repeated across 3+ scenarios |\n| GF011 | And/But as the first step in a scenario |"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "gherkinFlow.runScenario",
          "when": "resourceExtname == .feature",
          "group": "navigation@1"
        },
        {
          "command": "gherkinFlow.runFeature",
          "when": "resourceExtname == .feature",
          "group": "navigation@2"
        }
      ]
    },
    "configurationDefaults": {
      "[gherkin]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.detectIndentation": false
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.11.0",
    "@vscode/test-electron": "^2.5.0"
  }
}
