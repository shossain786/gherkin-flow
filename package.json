{
  "name": "gherkin-flow",
  "displayName": "Gherkin Flow",
  "description": "Run Cucumber scenarios directly from .feature files in VS Code — with step-by-step results, CodeLens run buttons, and Test Explorer integration.",
  "version": "0.7.0",
  "publisher": "RazaTech",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/shossain786/gherkin-flow"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Testing"
  ],
  "keywords": [
    "cucumber",
    "cucumber runner",
    "gherkin",
    "bdd",
    "testing",
    "test runner",
    "maven",
    "gradle",
    "feature",
    "scenario",
    "java",
    "cucumber jvm",
    "step definitions",
    "automation"
  ],
  "activationEvents": [
    "workspaceContains:**/*.feature"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "gherkin",
        "aliases": ["Gherkin", "Cucumber"],
        "extensions": [".feature"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gherkin",
        "scopeName": "text.gherkin.feature",
        "path": "./syntaxes/gherkin.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "gherkinFlow.runScenario",
        "title": "Run Scenario (GherkinFlow)",
        "category": "GherkinFlow"
      },
      {
        "command": "gherkinFlow.runFeature",
        "title": "Run Feature File (GherkinFlow)",
        "category": "GherkinFlow"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "gherkinFlow.runScenario",
          "when": "resourceExtname == .feature",
          "group": "navigation@1"
        },
        {
          "command": "gherkinFlow.runFeature",
          "when": "resourceExtname == .feature",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.11.0",
    "@vscode/test-electron": "^2.5.0"
  }
}
